# Crawl4AI Environment Variables

# 若无需在 Crawl4AI 中使用 LLM, 可直接删除本文件
# 并注释掉 docker-compose.yml 中 Crawl4AI
# environment:
#   - ENV_FILE=./.llm.env
# 一节

# 容器内通信端口
# APP_PORT=11235

OPENAI_API_KEY=请填入OpenAI API Key
# Crawl4AI 所用的模型名称
LLM_PROVIDER=Qwen3.5
# Crawl4AI 模型地址, 示例：
# LLM_BASE_URL=https://openai.example.com/v1
LLM_BASE_URL=https://openai.example.cn/v1
# 模型温度(可选)
OPENAI_TEMPERATURE=0.2