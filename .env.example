# 容器栈外部网络名称, 请根据实际情况修改为您的 Docker 网络名称
DOCKER_NETWORK=example_network

# =================================================

# OpenWebUI 配置
OPENWEBUI_PORT=请手动填入OpenWebUI的对外暴露端口
OPENWEBUI_SECRET_KEY=请手动填入OpenWebUI的SECRET
# OpenWebUI 监听的 IP 地址, 请根据实际情况修改为您的服务器 IP 地址
OPENWEBUI_IP=192.168.8.8
# OpenWebUI 域名, 请根据实际情况修改为您的域名, 如果不使用域名访问可以保持默认值
OPENWEBUI_DOMAIN=openwebui.example.com
# OPENWEBUI 数据目录, 用于存储OpenWebUI的相关数据, 包括模型文件、用户数据等
OPENWEBUI_DATA_PATH=/mnt/openwebui
# OPENWEBUI NLTK 目录, 用于存储NLTK相关数据, 包括词库、语料库等
# 当自动下载NLTK数据失败时, 可以手动下载NLTK数据并将其放置在该目录下, 然后取消注释该行
# OPENWEBUI_NLTK_PATH=/mnt/NLTK

# =================================================

# PostgreSQL 配置
POSTGRES_USER=请手动填入Postgres用户名
POSTGRES_PASSWORD=请手动填入Postgres密码
POSTGRES_DB=postgres
# PostgreSQL 数据目录, 用于存储 PostgreSQL 的相关数据, 包括数据库文件、日志文件等
POSTGRES_DATA_PATH=/mnt/postgres

# =================================================

# Qdrant 配置
VECTOR_DB=qdrant
QDRANT_API_KEY=请手动填入Qdrant的APIKEY
# Qdrant 数据目录, 用于存储 Qdrant 的相关数据, 包括数据库文件、日志文件等
QDRANT_DATA_PATH=/mnt/qdrant

# =================================================

# Valkey 配置
VALKEY_PASSWORD=请手动填入Valkey密码
# Valkey 数据目录, 用于存储 Valkey 的相关数据, 包括数据库文件、日志文件等
VALKEY_DATA_PATH=/mnt/valkey

# =================================================

# vLLM 配置
# 镜像地址, 可以根据实际情况选择适合的 vLLM 镜像, 默认使用官方最新的 vLLM OpenAI 镜像
VLLM_IMAGE=vllm/vllm-openai:latest
# 这是用于 Blackwell 显卡的最新 vLLM cu130 镜像地址
# VLLM_IMAGE=vllm/vllm-openai:latest-cu130
VLLM_API_KEY=请手动填入vLLM的APIKEY
# vLLM 缓存目录
VLLM_CACHE_DIR=/mnt/vllm-cache
# vLLM 模型存放目录
VLLM_MODELS_DIR=/mnt/vllm-models
# 模型文件夹名称（对应模型目录下的子目录, 例如 /mnt/vllm-models/Qwen3.5-35B/）
VLLM_MODEL_DIR_NAME=Qwen3.5-35B
# 对外提供的模型名称
VLLM_SERVED_MODEL_NAME=Qwen3.5
VLLM_RUNNER=auto
# vLLM 模型最大长度, 可以根据实际情况调整
# 但需要注意的是, 模型最大长度越大, 对 GPU 内存的需求也越大
VLLM_MAX_MODEL_LEN=256K
# 另一种设置模型最大长度的方式, 16*1024=16384, 即16K
# MAX_MODEL_LEN=16384
# vLLM 同时处理的最大序列数, 可以根据实际情况调整
VLLM_MAX_NUM_SEQS=128
# vLLM 模型权重和激活的数据类型
VLLM_DTYPE=auto
# GPU 内存利用率, 可以根据实际情况调整, 但需要注意的是, 设置过高可能会导致 OOM 错误
VLLM_GPU_MEMORY_UTILIZATION=0.9
# 指定使用的 GPU 编号
VLLM_GPU_DEVICE_ID=0
# 额外参数扩展
# 以下参数启用了推理解析器、自动工具选择、工具调用解析器和前缀缓存, 适用于 Qwen3.5 模型
VLLM_EXTRA_ARGS=--reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder --enable-prefix-caching
# 以下示例参数启用了推理解析器、自动工具选择、工具调用解析器、前缀缓存和共享内存缓存, 适用于 Qwen3.5 模型
# VLLM_EXTRA_ARGS=--reasoning-parser qwen3 --mm-processor-cache-type shm --enable-auto-tool-choice --tool-call-parser qwen3_coder --enable-prefix-caching
#
# =========================================================
# 不同模型的配置可能会大相径庭, 请根据实际情况调整以下参数:
# https://docs.vllm.ai/projects/recipes/en/latest/index.html
# 以及参阅: 
# https://docs.vllm.ai/en/stable/configuration/env_vars/
# =========================================================
#
# =================================================
# 常见参数说明 (取消注释并修改 VLLM_EXTRA_ARGS 使用):
# =================================================
#
# --enforce-eager
#   是否强制使用 eager 模式 PyTorch。如果为 True，将禁用 CUDA graph 并始终使用 eager 模式执行。
#   如果为 False，将使用 CUDA graph 和 eager 执行混合模式，以获得最佳性能和灵活性。
#   默认值: False
#
# --async-scheduling
#   是否启用异步调度。异步调度有助于减少 GPU 利用率空隙，从而提高延迟和吞吐量。
#   适用于高并发场景、需要更好吞吐量的场景
#   默认值: True
#
# --enable-prefix-caching
#   是否启用前缀缓存。启用后，相同前缀的请求可以复用已计算的 KV cache，显著提升推理性能。
#   适用于: 对话系统、多轮对话、重复性高的请求
#   默认值: False
#
# --enable-expert-parallel 或 -ep
#   是否使用专家并行 (Expert Parallelism) 替代 MoE 层的张量并行。
#   适用于: MoE (Mixture of Experts) 模型，如 Mixtral、Grok 等
#   默认值: False
#
# --speculative-config
#   投机解码配置，用于减少推理延迟。通过使用较小的 Draft 模型预测 token，然后用主模型验证。
#   示例: --speculative-config '{"method": "mtp", "num_speculative_tokens": 1}'
#   或者 --speculative-config '{"method": "qwen3_5_mtp", "num_speculative_tokens": 2}'
#   适用于需要更低延迟的场景
#
# --limit-mm-per-prompt
#   每个提示中允许的多模态输入数量限制。
#   示例: --limit-mm-per-prompt='{"image": 1, "video": 0}'
#   适用于多模态模型
#
# --mm-processor-cache-type
#   多模态处理器缓存类型。
#   可选值: lru (LRU 缓存), shm (共享内存 FIFO 缓存)
#   适用于多模态模型，可提升处理速度
#   默认值: lru
#
# --mm-processor-cache-gb
#   多模态处理器缓存大小 (单位: GiB)。
#   缓存可以避免重复处理过去的多模态输入。
#   适用于多模态模型
#   默认值: 4
#
# --mm-encoder-tp-mode
#   多模态编码器的张量并行模式。
#   可选值: data (数据并行), weights (权重并行)
#   适用于多模态模型，需要多 GPU 部署
#   默认值: weights
#
# --mm-encoder-only
#   当启用时，跳过模型的语言组件。这通常仅在 disaggregated Encoder 过程中有效。
#   适用于: 分离式编码器部署
#
# --tensor-parallel-size 或 -tp
#   张量并行组数量。用于在多 GPU 上分割模型。
#   需要多 GPU 部署
#   默认值: 1
#
# --gpu-memory-utilization
#   GPU 内存用于模型执行器的比例 (0 到 1)。调整内存使用，避免 OOM
#   例如 0.5 表示 50% GPU 内存利用率。
#   默认值: 0.9
#
# --max-model-len
#   模型上下文长度 (prompt + output)。如果不指定，将自动从模型配置派生。
#   支持人类可读格式: 1k, 1K, 25.6k, 256K, 1M 等
#   适用于: 需要调整上下文长度的模型
#   示例: --max-model-len=256K
#
# --max-num-seqs
#   单次迭代中可处理的最大序列数。调整并发处理能力
#   默认值: 256
#
# --dtype
#   模型权重和激活的数据类型。调整精度以节省显存或提升性能
#   可选值: auto, bfloat16, float, float16, float32, half
#   默认值: auto
#
# --kv-cache-dtype
#   KV cache 存储的数据类型。
#   可选值: auto, bfloat16, fp8, fp8_e4m3, fp8_e5m2, fp8_inc
#   适用于: 量化 KV cache 以节省显存
#   默认值: auto
#
# --swap-space
#   每个 GPU 的 CPU 交换空间大小 (单位: GiB)。可将 KV cache 卸载到 CPU
#   默认值: 4
#
# --disable-log-stats
#   禁用日志统计信息输出。
#   适用于: 生产环境减少日志噪音
#   默认值: False
#
# --disable-fastapi-docs
#   禁用 FastAPI 的 OpenAPI schema、Swagger UI 和 ReDoc 端点。
#   默认值: False

# ================================================

# OpenTerminal 配置
OPENTERMINAL_API_KEY=请手动填入OpenTerminal的APIKEY
# OpenTerminal 工作目录
OPENTERMINAL_WORKING_PATH=/mnt/terminal

# =================================================

# MCPO 配置
MCPO_API_KEY=请手动填入MCPO的APIKEY
# MCPO 数据目录
MCPO_CONFIG_PATH=/mnt/mcpo

# =================================================

# Playwright 配置
# 版本必须要与 OpenWebUI 中的版本一致，否则可能会出现连接失败问题
PLAYWRIGHT_VERSION=1.58.0
# Playwright 镜像的发行版后缀（noble=Ubuntu 24.04，jammy=Ubuntu 22.04）
PLAYWRIGHT_DISTRO=noble